{
  "manifest_version": 3,
  "name": "MLB The Show Inventory Exporter",
  "version": "0.3.0",
  "description": "Exports visible MLB The Show card inventory UUIDs as JSON or CSV for the local Card Explorer app.",
  "permissions": [
    "activeTab",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://*.theshow.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.theshow.com/*",
        "file:///*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "Export MLB Inventory",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
